local function getAllProximityPrompts()
    local prompts = {}
    for _,v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            local isPlayer = false
            for _,p in ipairs(Players:GetPlayers()) do
                if p.Character and v:IsDescendantOf(p.Character) then isPlayer=true break end
            end
            if not isPlayer then table.insert(prompts,v) end
        end
    end
    return prompts
end

local function safeFirePrompt(pp)
    if fireproximityprompt then
        fireproximityprompt(pp)
    elseif firetouchinterest then
        firetouchinterest(LP.Character and LP.Character:FindFirstChild("HumanoidRootPart"), pp.Parent, 0)
    end
end

local function lootAll()
    if looting then looting=false return end
    looting=true
    local char=LP.Character
    if not char then looting=false return end
    local root=char:FindFirstChild("HumanoidRootPart")
    if not root then looting=false return end
    local originalCF=root.CFrame
    local prompts=getAllProximityPrompts()
    for _,pp in ipairs(prompts) do
        if not looting then break end
        pcall(function()
            local part=pp.Parent
            if part then
                if part:IsA("BasePart") then
                    root.CFrame=CFrame.new(part.Position+Vector3.new(0,3,0))
                elseif part:IsA("Model") then
                    local rp=part:FindFirstChildOfClass("BasePart")
                    if rp then root.CFrame=CFrame.new(rp.Position+Vector3.new(0,3,0)) end
                end
            end
            task.wait(lootSpeed)
            safeFirePrompt(pp)
            task.wait(lootSpeed)
            safeFirePrompt(pp)
        end)
        task.wait(lootSpeed)
    end
    task.wait(0.2)
    pcall(function() if root and root.Parent then root.CFrame=originalCF end end)
    looting=false
end

local function applyInstantCollect()
    for _,v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            local isPlayer=false
            for _,p in ipairs(Players:GetPlayers()) do
                if p.Character and v:IsDescendantOf(p.Character) then isPlayer=true break end
            end
            if not isPlayer then v.HoldDuration=0 end
        end
    end
end

workspace.DescendantAdded:Connect(function(v)
