local function isZombie(name)
    name = name:lower()
    for _,kw in ipairs(zombieNames) do
        if name==kw or name:find(kw) then return true end
    end
    return false
end

local function getItemName(obj)
    return itemNames[obj.Name] or obj.Name
end

local function removeESP(obj)
    if espHighlights[obj] then espHighlights[obj]:Destroy() espHighlights[obj]=nil end
    if espLabels[obj] then espLabels[obj]:Destroy() espLabels[obj]=nil end
end

local function addPlayerESP(p)
    if p==LP or not p.Character or espHighlights[p] then return end
    local hl = Instance.new("Highlight")
    hl.FillColor = Color3.fromRGB(0,100,255)
    hl.OutlineColor = Color3.fromRGB(100,180,255)
    hl.FillTransparency = 0.5
    hl.OutlineTransparency = 0
    hl.Adornee = p.Character
    hl.Parent = p.Character
    espHighlights[p] = hl
end

local function addZombieESP(obj)
    if espHighlights[obj] then return end
    local hl = Instance.new("Highlight")
    hl.FillColor = Color3.fromRGB(255,0,0)
    hl.OutlineColor = Color3.fromRGB(255,80,80)
    hl.FillTransparency = 0.5
    hl.OutlineTransparency = 0
    hl.Adornee = obj
    hl.Parent = obj
    espHighlights[obj] = hl
end

local function addCarESP(obj)
    if espHighlights[obj] then return end
    local hl = Instance.new("Highlight")
    hl.FillColor = Color3.fromRGB(101,67,33)
    hl.OutlineColor = Color3.fromRGB(210,140,60)
    hl.FillTransparency = 0.5
    hl.OutlineTransparency = 0
    hl.Adornee = obj
    hl.Parent = obj
    espHighlights[obj] = hl
end

local function addItemESP(obj)
    if espHighlights[obj] then return end
    local count = 0
    for o,_ in pairs(espHighlights) do
        if typeof(o)=="Instance" and o:IsA("Tool") then count+=1 end
    end
    if count >= MAX_ITEM_ESP then return end
    local hl = Instance.new("Highlight")
    hl.FillColor = Color3.fromRGB(144,238,144)
    hl.OutlineColor = Color3.fromRGB(144,238,144)
    hl.FillTransparency = 0.4
    hl.OutlineTransparency = 0
    hl.Adornee = obj
    hl.Parent = obj
    espHighlights[obj] = hl
    local handle = obj:FindFirstChild("Handle")
    if handle then
        local bb = Instance.new("BillboardGui")
        bb.Size = UDim2.new(0,80,0,20)
        bb.StudsOffset = Vector3.new(0,3,0)
        bb.AlwaysOnTop = true
        bb.Parent = handle
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1,0,1,0)
        lbl.BackgroundTransparency = 1
        lbl.Text = getItemName(obj)
        lbl.TextColor3 = Color3.fromRGB(0,100,0)
        lbl.TextScaled = false
        lbl.TextSize = 10
        lbl.Font = Enum.Font.GothamBold
        lbl.Parent = bb
        local stroke = Instance.new("UIStroke")
        stroke.Color = Color3.fromRGB(0,0,0)
        stroke.Thickness = 2
        stroke.Parent = lbl
        espLabels[obj] = bb
    end
end

local function refreshPlayerESP()
    for p,_ in pairs(espHighlights) do
        if typeof(p)=="Instance" and p:IsA("Player") then removeESP(p) end
    end
    if not Cfg.ESPPlayers then return end
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LP and p.Character then addPlayerESP(p) end
    end
end

local function refreshZombieESP()
    for obj,_ in pairs(espHighlights) do
        if typeof(obj)=="Instance" and obj:IsA("Model") then
            local hum = obj:FindFirstChildOfClass("Humanoid")
            if hum then removeESP(obj) end
        end
    end
    if not Cfg.ESPZombies then return end
    for _,obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") then
            local hum = obj:FindFirstChildOfClass("Humanoid")
            local isPlayer = false
            for _,p in ipairs(Players:GetPlayers()) do
                if p.Character==obj then isPlayer=true break end
            end
            if hum and not isPlayer and isZombie(obj.Name) then addZombieESP(obj) end
        end
    end
end

local function refreshCarESP()
    for obj,_ in pairs(espHighlights) do
        if typeof(obj)=="Instance" and obj:IsA("Model") and obj:FindFirstChildOfClass("VehicleSeat") then
            removeESP(obj)
        end
    end
    if not Cfg.ESPCars then return end
    for _,obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChildOfClass("VehicleSeat") then addCarESP(obj) end
    end
end

local function refreshItemESP()
    for obj,_ in pairs(espHighlights) do
        if typeof(obj)=="Instance" and obj:IsA("Tool") then removeESP(obj) end
    end
    if not Cfg.ESPItems then return end
    for _,obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Tool") then
            local isPlayer = false
            for _,p in ipairs(Players:GetPlayers()) do
                if p.Character and obj:IsDescendantOf(p.Character) then isPlayer=true break end
                if obj:IsDescendantOf(p.Backpack) then isPlayer=true break end
            end
            if not isPlayer then addItemESP(obj) end
        end
    end
end

