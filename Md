local Cfg = _G.RZRMCfg
local Players = game:GetService("Players")
local RS = game:GetService("RunService")
local LP = Players.LocalPlayer

local flying = false
local flySpeed = 50
local flyConn = nil
local bv = nil
local bg = nil

local function startFly()
    local char = LP.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not root or not hum then return end
    hum.PlatformStand = true
    if bv then bv:Destroy() end
    if bg then bg:Destroy() end
    bv = Instance.new("BodyVelocity")
    bv.Velocity = Vector3.zero
    bv.MaxForce = Vector3.new(1e6,1e6,1e6)
    bv.Parent = root
    bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(1e6,1e6,1e6)
    bg.D = 50
    bg.P = 1000
    bg.Parent = root
    if flyConn then flyConn:Disconnect() end
    flyConn = RS.Heartbeat:Connect(function(dt)
        if not flying then return end
        if not root or not root.Parent then return end
        hum.PlatformStand = true
        local cam = workspace.CurrentCamera
        local camCF = cam.CFrame
        local moveDir = hum.MoveDirection
        local velocity = Vector3.zero
        if moveDir.Magnitude > 0 then
            local flatForward = Vector3.new(camCF.LookVector.X,0,camCF.LookVector.Z)
            local flatRight = Vector3.new(camCF.RightVector.X,0,camCF.RightVector.Z)
            if flatForward.Magnitude > 0 then flatForward=flatForward.Unit end
            if flatRight.Magnitude > 0 then flatRight=flatRight.Unit end
            local fwdDot = Vector3.new(moveDir.X,0,moveDir.Z):Dot(flatForward)
            local rightDot = Vector3.new(moveDir.X,0,moveDir.Z):Dot(flatRight)
            local fullDir = (camCF.LookVector * fwdDot) + (camCF.RightVector * rightDot)
            if fullDir.Magnitude > 0 then
                velocity = fullDir.Unit * flySpeed
            end
        end
        bv.Velocity = velocity
        bg.CFrame = camCF
    end)
end

local function stopFly()
    flying = false
    if flyConn then flyConn:Disconnect() flyConn=nil end
    if bv then bv:Destroy() bv=nil end
    if bg then bg:Destroy() bg=nil end
    local char = LP.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then hum.PlatformStand=false end
end

local noclipping = false
local noclipConn = nil

local function startNoclip()
    if noclipConn then noclipConn:Disconnect() end
    noclipConn = RS.Stepped:Connect(function()
        if not noclipping then return end
        local char = LP.Character
        if not char then return end
        for _,part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide then
                part.CanCollide = false
            end
        end
    end)
end

local function stopNoclip()
    noclipping = false
    if noclipConn then noclipConn:Disconnect() noclipConn=nil end
    local char = LP.Character
    if not char then return end
    for _,part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then part.CanCollide=true end
    end
end

local noFallConn = nil
local charFallConn = nil
local noStaminaConn = nil

-- Fullbright + No Fog
local Lighting = game:GetService("Lighting")
local fullbrightConn = nil

local function applyFullbright()
    Lighting.Brightness = 2
    Lighting.ClockTime = 14
    Lighting.FogEnd = 100000
    Lighting.FogStart = 100000
    Lighting.GlobalShadows = false
    Lighting.Ambient = Color3.fromRGB(255,255,255)
    Lighting.OutdoorAmbient = Color3.fromRGB(255,255,255)
    for _,v in ipairs(Lighting:GetChildren()) do
        if v:IsA("Atmosphere") then
            v.Density = 0
            v.Offset = 0
        end
    end
end

